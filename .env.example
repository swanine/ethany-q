# Ethany-Q API（切勿将真实 .env 提交到 Git）
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# true=测试网 REST https://testnet.binancefuture.com
BINANCE_TESTNET=false

# 逗号分隔或 JSON 数组，例如：
# TRADING_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
TRADING_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,SUIUSDT

DEFAULT_LEVERAGE=5
MARGIN_MODE=CROSSED
MAX_PORTFOLIO_EXPOSURE_PCT=0.8

# 全局：达到该回撤比例（相对历史峰值权益）时停止开新仓（0.15=15%）
MAX_DRAWDOWN_PCT=0.15

# 单笔最大风险占权益比例（0.015=1.5%）
MAX_RISK_PER_TRADE_PCT=0.015

# 单标的最大名义敞口占权益比例上限（名义价值 ≤ 权益 × 本值，再与 ATR 风险上限取小）
MAX_SYMBOL_EXPOSURE_PCT=0.25

# 可选：各标的仓位权重（JSON）。最终数量 = 风控基础数量 × 权重；未列出默认 1.0
# 示例：BTC/ETH 略大、山寨略小
# SYMBOL_WEIGHTS={"BTCUSDT":1.625,"ETHUSDT":1.625,"SOLUSDT":0.583,"XRPUSDT":0.583,"SUIUSDT":0.583}

# 最大同时持仓标的数量
MAX_OPEN_POSITIONS=5

# Telegram 机器人通知
TG_BOT_TOKEN=your_tg_bot_token_here
TG_CHAT_ID=your_tg_chat_id_here
# 推送级别：all=全部  order=仅开平仓  alert=仅告警  off=关闭
TG_NOTIFY_LEVEL=all

# REST recvWindow（毫秒）
BINANCE_RECV_WINDOW=5000

# WebSocket 断线重连初始等待（秒）
WS_RECONNECT_DELAY_SEC=2

# REST 最大重试次数
REST_MAX_RETRIES=5

# 回测：默认 taker 手续费与滑点
BACKTEST_TAKER_FEE_RATE=0.0004
BACKTEST_SLIPPAGE_PCT=0.0002